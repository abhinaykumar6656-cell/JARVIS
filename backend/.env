# ===================================
# APPLICATION
# ===================================

APP_NAME=JARVIS
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# ===================================
# SERVER
# ===================================

HOST=127.0.0.1
PORT=8000

# ===================================
# SECURITY
# ===================================

SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================================
# DATABASE
# ===================================

DATABASE_URL=sqlite:///./data/jarvis.db

# ===================================
# LOGGING
# ===================================

LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# ===================================
# AI
# ===================================

DEFAULT_LLM=ollama
OLLAMA_URL=http://localhost:11434

# ===================================
# VOICE
# ===================================

WAKE_WORD=Jarvis
SLEEP_TIMEOUT=300
